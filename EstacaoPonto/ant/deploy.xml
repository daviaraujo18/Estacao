<?xml version="1.0" encoding="UTF-8"?>

<!-- ANT SCRIPT TO BUILD THE DEPLOYED APPLICATION -->
<project name="deployBuild"  default="run" basedir="../" xmlns:fx="javafx:com.sun.javafx.tools.ant">

    <target name="run">
        <echo message="Running"/>
        <fx:deploy width="${javafx.run.width}"
                   height="${javafx.run.height}"
                   nativeBundles="all"
                   outdir="${basedir}/distE"
                   outfile="core.EstacaoPonto">
            <fx:application name="EstacaoPonto" mainClass="core.EstacaoPonto.class"/>

            <fx:resources>
                <fx:fileset dir="${basedir}/distE" includes="*.jar"/>
            </fx:resources>
            <fx:info title="core.EstacaoPonto" vendor="TJPI"/>
        </fx:deploy>
    </target>
</project>