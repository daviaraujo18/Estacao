<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="LogToConsole" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS}{GMT-3} %c{1} &#9; %-5level - %msg%n"/>
        </Console>

        <RollingFile name="LogFullToRollingFile" fileName="C:/estacao/log/full.txt"
                     filePattern="C:/estacao/log/$${date:yyyy-MM}/full-%d{MM-dd-yyyy}-%i.txt">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss.SSS}{GMT-3} %c{1} &#9; %-5level - %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
        </RollingFile>

        <RollingFile name="LogAplicacaoToRollingFile" fileName="C:/estacao/log/app.txt"
                     filePattern="C:/estacao/log/$${date:yyyy-MM}/app-%d{MM-dd-yyyy}-%i.txt">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss.SSS}{GMT-3} %-5level - %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
        </RollingFile>

        <RollingFile name="LogEstacaoToRollingFile" fileName="C:/estacao/log/estacao.txt"
                     filePattern="C:/estacao/log/$${date:yyyy-MM}/estacao-%d{MM-dd-yyyy}-%i.txt">
            <PatternLayout>
                <Pattern>%d{HH:mm:ss.SSS}{GMT-3} %-5level - %msg%n</Pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy />
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
        </RollingFile>

    </Appenders>

    <Loggers>
        <!-- avoid duplicated logs with additivity=false -->
        <Logger name="utils.LogAplicacao" level="trace" additivity="true">
            <AppenderRef ref="LogAplicacaoToRollingFile"/>
        </Logger>
        <Logger name="utils.LogEstacao" level="trace" additivity="true">
            <AppenderRef ref="LogEstacaoToRollingFile"/>
        </Logger>
        <Root level="trace">
            <!--<AppenderRef ref="LogToConsole"/>-->
            <AppenderRef ref="LogFullToRollingFile"/>
        </Root>
    </Loggers>
</Configuration>